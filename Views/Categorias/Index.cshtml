@model List<AgenticContextEngine.Models.CategoriaAgente>
@{
    ViewData["Title"] = "Categorias"; Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = Context.Session.GetString("UsuarioPerfil") == "Administrador";
    var podeCriar = Context.Session.GetString("UsuarioPerfil") != "Convidado";
    var currentUserId = int.TryParse(Context.Session.GetString("UsuarioId"), out var uid) ? uid : (int?)null;
}
<div class="content">
    @if (TempData["Erro"] != null)
    {
        <div style="background: rgba(239,68,68,.12); border: 1px solid #ef4444; color: #fca5a5; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 13px;">
            @TempData["Erro"]
        </div>
    }
    @if (TempData["Sucesso"] != null)
    {
        <div style="background: rgba(16,185,129,.12); border: 1px solid #10b981; color: #6ee7b7; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 13px;">
            @TempData["Sucesso"]
        </div>
    }
    <div class="page-header">
        <div><h1 class="page-title">Categorias de Agentes</h1><p class="page-sub">Gerencie as categorias do Agentic Context Engine</p></div>
        @if (podeCriar)
        {
            <a href="/Categorias/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Nova Categoria</a>
        }
    </div>
    <div class="stats-grid">
        <div class="stat-card sc-blue"><div class="stat-top"><div class="stat-icon si-blue"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z" /></svg></div><span class="stat-badge sb-blue">Total</span></div><div class="stat-label">Total de Categorias</div><div class="stat-val">@Model.Count</div><div class="stat-sub">Cadastradas no sistema</div></div>
        <div class="stat-card sc-green"><div class="stat-top"><div class="stat-icon si-green"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div><span class="stat-badge sb-green">Ativas</span></div><div class="stat-label">Categorias Ativas</div><div class="stat-val">@Model.Count(c => c.Ativo)</div><div class="stat-sub"><span class="trend-up">Em uso</span></div></div>
        <div class="stat-card sc-purple"><div class="stat-top"><div class="stat-icon si-purple"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18" /></svg></div><span class="stat-badge sb-purple">Agentes</span></div><div class="stat-label">Agentes Vinculados</div><div class="stat-val">@ViewBag.TotalAgentes</div><div class="stat-sub">Usando categorias</div></div>
        <div class="stat-card sc-amber"><div class="stat-top"><div class="stat-icon si-amber"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg></div><span class="stat-badge sb-amber">Msgs</span></div><div class="stat-label">Conversas Processadas</div><div class="stat-val">@ViewBag.TotalMensagens</div><div class="stat-sub"><span class="trend-up">+12% este mes</span></div></div>
    </div>
    <div class="tcard">
        <div class="thead-row">
            <span class="thead-title">Todas as Categorias</span>
            <div class="toolbar">
                <div class="search-wrap"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg><input type="text" placeholder="Buscar..." oninput="filtrar(this.value,'tbody-cat')" /></div>
                <select class="filter-select" onchange="filtrarStatus(this.value,'tbody-cat')"><option value="">Todos</option><option value="ativo">Ativo</option><option value="inativo">Inativo</option></select>
                @if (podeCriar)
                {
                    <a href="/Categorias/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Nova</a>
                }
            </div>
        </div>
        <table>
            <thead><tr><th>#</th><th>Categoria</th><th>Descricao</th><th>Status</th><th>Criado em</th><th>Ações</th></tr></thead>
            <tbody id="tbody-cat">
                @{
                    int i = 0;
                }
                @foreach (var c in Model)
                {
                    i++;
                    <tr>
                        <td class="td-num">@i.ToString("D2")</td>
                        <td><div class="td-name"><div class="td-icon ti-blue"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A2 2 0 013 12V7a4 4 0 014-4z" /></svg></div>@c.Nome</div></td>
                        <td class="td-muted">@c.Descricao</td>
                        <td>@if(c.Ativo){
                            <span class="badge b-green"><span class="dot dot-green"></span>Ativo</span>
                        }else
                        {

                            <span class="badge b-red"><span class="dot dot-red"></span>Inativo</span>
                        }
                    </td>
                    <td class="td-muted">@c.DataCriacao.ToString("dd/MM/yyyy")</td>
                    <td>
                        <template id="view-categoria-@c.Id">
                            <div class="vrow"><span class="vlabel">Nome</span><span class="vvalue">@c.Nome</span></div>
                            <div class="vrow"><span class="vlabel">Descrição</span><span class="vvalue">@(c.Descricao ?? "-")</span></div>
                            <div class="vrow"><span class="vlabel">Status</span><span class="vvalue">@(c.Ativo ? "Ativo" : "Inativo")</span></div>
                            <div class="vrow"><span class="vlabel">Criado em</span><span class="vvalue">@c.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span></div>
                        </template>
                        <div class="td-actions">
                            <a href="#" class="act act-view" title="Visualizar" onclick="abrirModalView('view-categoria-@c.Id','@c.Nome'); return false;"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></a>
                            @if (isAdmin || c.CriadoPorUsuarioId == currentUserId)
                            {
                                <a href="/Categorias/Editar/@c.Id" class="act act-edit" title="Editar"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></a>
                                <a href="/Categorias/Excluir/@c.Id" class="act act-del" title="Excluir" onclick="return confirm('Excluir?')"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="tfoot-row"><span class="tfoot-info">Mostrando @Model.Count categorias</span><div class="pag"><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg></a><a href="#" class="pg on">1</a><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg></a></div></div>
</div>
</div>