@model List<AgenticContextEngine.Models.CanalOrigem>
@{
    ViewData["Title"] = "Canais"; Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = Context.Session.GetString("UsuarioPerfil") == "Administrador";
    var podeCriar = Context.Session.GetString("UsuarioPerfil") != "Convidado";
    var currentUserId = int.TryParse(Context.Session.GetString("UsuarioId"), out var uid) ? uid : (int?)null;
}
<div class="content">
    @if (TempData["Erro"] != null)
    {
        <div style="background: rgba(239,68,68,.12); border: 1px solid #ef4444; color: #fca5a5; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 13px;">
            @TempData["Erro"]
        </div>
    }
    @if (TempData["Sucesso"] != null)
    {
        <div style="background: rgba(16,185,129,.12); border: 1px solid #10b981; color: #6ee7b7; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 13px;">
            @TempData["Sucesso"]
        </div>
    }
    <div class="page-header">
        <div><h1 class="page-title">Canais de Origem</h1><p class="page-sub">Gerencie os sites e canais conectados a plataforma</p></div>
        @if (podeCriar)
        {
            <a href="/Canais/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Novo Canal</a>
        }
    </div>
    <div class="stats-grid">
        <div class="stat-card sc-blue"><div class="stat-top"><div class="stat-icon si-blue"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3" /></svg></div><span class="stat-badge sb-blue">Total</span></div><div class="stat-label">Total de Canais</div><div class="stat-val">@Model.Count</div><div class="stat-sub">Canais cadastrados</div></div>
        <div class="stat-card sc-green"><div class="stat-top"><div class="stat-icon si-green"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div><span class="stat-badge sb-green">Ativos</span></div><div class="stat-label">Canais Ativos</div><div class="stat-val">@Model.Count(c => c.Ativo)</div><div class="stat-sub"><span class="trend-up">@(Model.Count > 0 ? Math.Round((double)Model.Count(c => c.Ativo) / Model.Count * 100) : 0)% do total</span></div></div>
        <div class="stat-card sc-amber"><div class="stat-top"><div class="stat-icon si-amber"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg></div><span class="stat-badge sb-amber">Operacao</span></div><div class="stat-label">Em Operacao</div><div class="stat-val">@Model.Count(c => c.Ativo)</div><div class="stat-sub">Operando normalmente</div></div>
        <div class="stat-card sc-purple"><div class="stat-top"><div class="stat-icon si-purple"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10" /></svg></div><span class="stat-badge sb-purple">Sessoes</span></div><div class="stat-label">Sessoes Abertas</div><div class="stat-val">@ViewBag.TotalSessoes</div><div class="stat-sub"><span class="trend-up">Total no banco</span></div></div>
    </div>
    <div class="tcard">
        <div class="thead-row">
            <span class="thead-title">Todos os Canais</span>
            <div class="toolbar">
                <div class="search-wrap"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg><input type="text" placeholder="Buscar..." oninput="filtrar(this.value,'tbody-ca')" /></div>
                <select class="filter-select" onchange="filtrarStatus(this.value,'tbody-ca')"><option value="">Todos</option><option value="ativo">Ativo</option><option value="inativo">Inativo</option></select>
                @if (podeCriar)
                {
                    <a href="/Canais/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Novo</a>
                }
            </div>
        </div>
        <table>
            <thead><tr><th>#</th><th>Canal</th><th>URL</th><th>Descricao</th><th>Status</th><th>Criado em</th><th>Acoes</th></tr></thead>
            <tbody id="tbody-ca">
                @{
                    int i = 0; string[] cols = { "ti-blue", "ti-green", "ti-amber", "ti-purple", "ti-cyan" };
                }
                @foreach (var c in Model)
                {
                    var col = cols[i % cols.Length]; i++;
                    <tr>
                        <td class="td-num">@i.ToString("D2")</td>
                        <td><div class="td-name"><div class="td-icon @col"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3" /></svg></div>@c.Nome</div></td>
                        <td><a href="@c.UrlSite" class="td-url" target="_blank">@c.UrlSite<svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg></a></td>
                        <td class="td-muted">@c.Descricao</td>
                        <td>@if(c.Ativo){
                            <span class="badge b-green"><span class="dot dot-green"></span>Ativo</span>
                        }else
                        {

                            <span class="badge b-red"><span class="dot dot-red"></span>Inativo</span>
                        }
                    </td>
                    <td class="td-muted">@c.DataCriacao.ToString("dd/MM/yyyy")</td>
                    <td>
                        <div class="td-actions">
                            <a href="#" class="act act-view" title="Visualizar"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></a>
                            @if (isAdmin || c.CriadoPorUsuarioId == currentUserId)
                            {
                                <a href="/Canais/Editar/@c.Id" class="act act-edit" title="Editar"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></a>
                                <a href="/Canais/Excluir/@c.Id" class="act act-del" title="Excluir" onclick="return confirm('Excluir?')"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="tfoot-row"><span class="tfoot-info">Mostrando @Model.Count canais</span><div class="pag"><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg></a><a href="#" class="pg on">1</a><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg></a></div></div>
</div>
</div>