@model List<AgenticContextEngine.Models.UsuarioListItemDto>
@{
    ViewData["Title"] = "Usuarios"; Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = Context.Session.GetString("UsuarioPerfil") == "Administrador";
}
<div class="content">
    @if (TempData["Erro"] != null)
    {
        <div style="background: rgba(239,68,68,.12); border: 1px solid #ef4444; color: #fca5a5; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 13px;">
            @TempData["Erro"]
        </div>
    }
    <div class="page-header">
        <div><h1 class="page-title">Usuarios do Sistema</h1><p class="page-sub">Gerencie usuarios e permissoes de acesso</p></div>
        @if (isAdmin)
        {
            <a href="/Usuarios/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Novo Usuario</a>
        }
    </div>
    <div class="stats-grid">
        <div class="stat-card sc-blue"><div class="stat-top"><div class="stat-icon si-blue"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" /></svg></div><span class="stat-badge sb-blue">Total</span></div><div class="stat-label">Total de Usuarios</div><div class="stat-val">@Model.Count</div><div class="stat-sub">No sistema</div></div>
        <div class="stat-card sc-green"><div class="stat-top"><div class="stat-icon si-green"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" /></svg></div><span class="stat-badge sb-green">Online</span></div><div class="stat-label">Usuarios Ativos</div><div class="stat-val">@Model.Count(u => u.Ativo)</div><div class="stat-sub"><span class="trend-up">Em uso</span></div></div>
        <div class="stat-card sc-purple"><div class="stat-top"><div class="stat-icon si-purple"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg></div><span class="stat-badge sb-purple">Admin</span></div><div class="stat-label">Administradores</div><div class="stat-val">@ViewBag.TotalAdmins</div><div class="stat-sub">Acesso total</div></div>
        <div class="stat-card sc-amber"><div class="stat-top"><div class="stat-icon si-amber"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg></div><span class="stat-badge sb-amber">Perfis</span></div><div class="stat-label">Perfis de Acesso</div><div class="stat-val">@ViewBag.TotalPerfis</div><div class="stat-sub">Administrador, Convidado</div></div>
    </div>
    <div class="tcard">
        <div class="thead-row">
            <span class="thead-title">Todos os Usuarios</span>
            <div class="toolbar">
                <div class="search-wrap"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg><input type="text" placeholder="Buscar..." oninput="filtrar(this.value,'tbody-us')" /></div>
                <select class="filter-select" onchange="filtrarStatus(this.value,'tbody-us')"><option value="">Todos</option><option value="ativo">Ativo</option><option value="inativo">Inativo</option></select>
                @if (isAdmin)
                {
                    <a href="/Usuarios/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Novo</a>
                }
            </div>
        </div>
        <table>
            <thead><tr><th>#</th><th>Usuario</th><th>Email</th><th>Perfil</th><th>Status</th><th>Cadastrado</th><th>Ações</th></tr></thead>
            <tbody id="tbody-us">
                @{
                    int i = 0;
                }
                @foreach (var u in Model)
                {
                    i++;
                    <tr>
                        <td class="td-num">@i.ToString("D2")</td>
                        <td><div class="td-name"><div class="td-icon ti-blue"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg></div>@u.Nome</div></td>
                        <td class="td-muted">@u.Email</td>
                        <td>@if(u.PerfilNome=="Administrador"){
                            <span class="badge b-purple">@u.PerfilNome</span>
                        }else if (u.PerfilNome == "Operador")
                        {

                            <span class="badge b-blue">@u.PerfilNome</span>
                        }
                        else
                        {

                            <span class="badge b-amber">@u.PerfilNome</span>
                        }
                    </td>
                    <td>@if(u.Ativo){
                        <span class="badge b-green"><span class="dot dot-green"></span>Ativo</span>
                    }else
                    {

                        <span class="badge b-red"><span class="dot dot-red"></span>Inativo</span>
                    }
                </td>
                <td class="td-muted">@u.DataCriacao.ToString("dd/MM/yyyy")</td>
                <td>
                    <template id="view-usuario-@u.Id">
                        <div class="vrow"><span class="vlabel">Nome</span><span class="vvalue">@u.Nome</span></div>
                        <div class="vrow"><span class="vlabel">Email</span><span class="vvalue">@u.Email</span></div>
                        <div class="vrow"><span class="vlabel">Perfil</span><span class="vvalue">@u.PerfilNome</span></div>
                        <div class="vrow"><span class="vlabel">Status</span><span class="vvalue">@(u.Ativo ? "Ativo" : "Inativo")</span></div>
                        <div class="vrow"><span class="vlabel">Cadastrado em</span><span class="vvalue">@u.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span></div>
                    </template>
                    <div class="td-actions">
                        <a href="#" class="act act-view" title="Visualizar" onclick="abrirModalView('view-usuario-@u.Id','@u.Nome'); return false;"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></a>
                        @if (isAdmin)
                        {
                            <a href="/Usuarios/Editar/@u.Id" class="act act-edit" title="Editar"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></a>
                            <a href="/Usuarios/Excluir/@u.Id" class="act act-del" title="Excluir" onclick="return confirm('Excluir?')"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></a>
                        }
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>
<div class="tfoot-row"><span class="tfoot-info">Mostrando @Model.Count usuarios</span><div class="pag"><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg></a><a href="#" class="pg on">1</a><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg></a></div></div>
</div>
</div>