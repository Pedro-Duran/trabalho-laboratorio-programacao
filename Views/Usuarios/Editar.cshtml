@model AgenticContextEngine.Models.UsuarioEditDto
@{ ViewData["Title"] = "Editar Usuário"; Layout = null; }
<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <title>Editar Usuário</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { background: #0f1117; font-family: sans-serif; color: #f1f5f9; display: flex; align-items: center; justify-content: center; min-height: 100vh; }
        .card { background: #1a1d27; border: 1px solid #2a2d3d; border-radius: 16px; padding: 40px; width: 100%; max-width: 480px; }
        h2 { font-size: 20px; margin-bottom: 28px; }
        .form-group { margin-bottom: 20px; }
        label { display: block; color: #94a3b8; font-size: 13px; margin-bottom: 8px; }
        input, select { width: 100%; background: #0f1117; border: 1px solid #2a2d3d; border-radius: 8px; padding: 12px 16px; color: #f1f5f9; font-size: 15px; outline: none; font-family: inherit; }
        input:focus, select:focus { border-color: #6366f1; }
        select option { background: #0f1117; color: #f1f5f9; }
        .btn { background: linear-gradient(135deg, #6366f1, #8b5cf6); color: white; border: none; border-radius: 8px; padding: 12px 24px; font-size: 15px; font-weight: 600; cursor: pointer; width: 100%; margin-top: 8px; }
        .link { display: block; text-align: center; margin-top: 16px; color: #6366f1; text-decoration: none; font-size: 14px; }
    </style>
</head>
<body>
    <div class="card">
        <h2>Editar Usuário</h2>
        @if (TempData["Erro"] != null)
        {
            <div style="background: rgba(239,68,68,.12); border: 1px solid #ef4444; color: #fca5a5; padding: 12px 16px; border-radius: 8px; margin-bottom: 20px; font-size: 13px;">
                @TempData["Erro"]
            </div>
        }
        <form method="post" action="/Usuarios/Editar">
            <input type="hidden" name="Id" value="@Model.Id" />
            <div class="form-group">
                <label>Nome</label>
                <input type="text" name="Nome" value="@Model.Nome" required />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="Email" value="@Model.Email" required />
            </div>
            <div class="form-group">
                <label>Nova Senha</label>
                <input type="password" name="NovaSenha" placeholder="Deixe em branco para manter a senha atual" autocomplete="new-password" />
            </div>
            <div class="form-group">
                <label>Senha Atual (obrigatória apenas para trocar a senha)</label>
                <input type="password" name="SenhaAtual" placeholder="Confirme a senha atual desta conta" autocomplete="current-password" />
            </div>
            <div class="form-group">
                <label>Perfil</label>
                <select name="PerfilAcessoId">
                    @foreach (var p in (List<AgenticContextEngine.Models.OpcaoSelecaoDto>)ViewBag.Perfis)
                    {
                        <option value="@p.Id" selected="@(p.Id == Model.PerfilAcessoId)">@p.Nome</option>
                    }
                </select>
            </div>
            <div class="form-group">
                <label>Status</label>
                <select name="Ativo">
                    <option value="true" selected="@Model.Ativo">Ativo</option>
                    <option value="false" selected="@(!Model.Ativo)">Inativo</option>
                </select>
            </div>
            <button type="submit" class="btn">Salvar</button>
        </form>
        <a href="/Usuarios/Index" class="link">&larr; Voltar</a>
    </div>
</body>
</html>