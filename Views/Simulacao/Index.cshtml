@model AgenticContextEngine.Models.ChatIndexViewModel
@{
    ViewData["Title"] = "Simulador de Chat";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content">
    <div class="page-header">
        <div>
            <h1 class="page-title">Interface de Simulação (Chat)</h1>
            <p class="page-sub">Selecione um Agente e um Canal de Origem para iniciar ou retomar uma sessão de atendimento</p>
        </div>
    </div>

    <div class="fcard" style="max-width: 500px; margin: 0 auto;">
        <div class="fcard-title">Configurar Sessão Agêntica</div>
        <form method="get" action="/Simulacao/Chat">
            <div class="fg">
                <label class="flabel">Agente Digital</label>
                <select name="agenteId" class="finput" required>
                    <option value="">-- Selecione o Agente --</option>
                    @foreach (var agente in Model.Agentes)
                    {
                        <option value="@agente.Id">@agente.Nome</option>
                    }
                </select>
            </div>

            <div class="fg">
                <label class="flabel">Canal / Site de Origem</label>
                <select name="canalOrigemId" class="finput" required>
                    <option value="">-- Selecione o Canal de Origem --</option>
                    @foreach (var canal in Model.Canais)
                    {
                        <option value="@canal.Id">@canal.Nome (@canal.UrlSite)</option>
                    }
                </select>
            </div>

            <div class="factions">
                <button type="submit" class="tbtn" style="width: 100%; justify-content: center;">
                    <svg viewBox="0 0 24 24" style="width:16px; height:16px;"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                    Conectar e Abrir Chat
                </button>
            </div>
        </form>
    </div>
</div>