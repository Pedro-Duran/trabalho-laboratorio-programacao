@model AgenticContextEngine.Models.ChatSessaoViewModel
@{
    ViewData["Title"] = "Simulação em Execução";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .chat-container { display: flex; flex-direction: column; height: calc(100vh - 160px); background: #0c0f1a; border: 1px solid #1e2d42; border-radius: 14px; overflow: hidden; }
    .chat-header { padding: 16px 24px; background: #111827; border-bottom: 1px solid #1e2d42; display: flex; align-items: center; justify-content: space-between; }
    .agent-info { display: flex; align-items: center; gap: 12px; }
    .chat-messages { flex: 1; padding: 24px; overflow-y: auto; display: flex; flex-direction: column; gap: 16px; background: #07090f; }
    .msg-box { max-width: 70%; padding: 12px 16px; border-radius: 12px; font-size: 13.5px; line-height: 1.5; word-break: break-word; }
    .msg-user { background: linear-gradient(135deg, #4f46e5, #6366f1); color: white; align-self: flex-end; border-bottom-right-radius: 2px; }
    .msg-agent { background: #1a2235; color: #f0f4ff; align-self: flex-start; border-bottom-left-radius: 2px; border: 1px solid #1e2d42; }
    .msg-meta { font-size: 10px; margin-top: 4px; display: block; opacity: 0.6; text-align: right; }
    .msg-agent .msg-meta { text-align: left; color: #8b5cf6; }
    .chat-footer { padding: 16px 24px; background: #111827; border-top: 1px solid #1e2d42; }
    .chat-form { display: flex; gap: 12px; }
</style>

<div class="content">
    <div class="page-header">
        <div>
            <h1 class="page-title">Execução Contextual Ativa</h1>
            <p class="page-sub">Retomando histórico persistido para o Agente selecionado.</p>
        </div>
        <a href="/Simulacao/Index" class="fcancel" style="padding: 9px 16px;">← Mudar Canal/Agente</a>
    </div>

    <div class="chat-container">
        <div class="chat-header">
            <div class="agent-info">
                <div class="td-icon ti-purple"><svg viewBox="0 0 24 24" style="width:20px;height:20px;"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18"/></svg></div>
                <div>
                    <strong style="color: #f0f4ff; font-size: 15px;">@Model.NomeAgente</strong>
                    <span class="badge b-purple" style="margin-left: 8px;">@Model.CategoriaAgente</span>
                </div>
            </div>
            <div>
                <span class="badge b-blue">Origem: @Model.NomeCanal</span>
            </div>
        </div>

        <div class="chat-messages" id="chatMessages">
            @if (!Model.Mensagens.Any())
            {
                <div style="text-align: center; color: #6b7a99; margin-top: 40px; font-style: italic;">
                    Nenhum histórico prévio neste canal. Envie uma mensagem para iniciar a gravação do contexto!
                </div>
            }
            else
            {
                @foreach (var msg in Model.Mensagens)
                {
                    bool isUser = msg.Remetente == "Usuário";
                    <div class="msg-box @(isUser ? "msg-user" : "msg-agent")">
                        <strong>@(isUser ? "Você" : msg.Remetente):</strong>
                        <p style="margin-top: 4px;">@msg.Conteudo</p>
                        <span class="msg-meta">@msg.DataEnvio.ToString("dd/MM HH:mm")</span>
                    </div>
                }
            }
        </div>

        <div class="chat-footer">
            <form method="post" action="/Simulacao/EnviarMensagem" class="chat-form">
                <input type="hidden" name="sessaoId" value="@Model.SessaoId" />
                <input type="text" name="conteudo" class="finput" placeholder="Digite uma mensagem (ex: testar palavras 'preço', 'erro', 'fatura')..." autocomplete="off" required />
                <button type="submit" class="tbtn" style="padding: 0 24px;">Enviar</button>
            </form>
        </div>
    </div>
</div>

<script>
    // Mantém o scroll do chat sempre no final das mensagens ao carregar
    var objDiv = document.getElementById("chatMessages");
    if(objDiv) { objDiv.scrollTop = objDiv.scrollHeight; }
</script>