@model List<AgenticContextEngine.Models.AgenteListItemDto>
@{
    ViewData["Title"] = "Agentes"; Layout = "~/Views/Shared/_Layout.cshtml";
    var isAdmin = Context.Session.GetString("UsuarioPerfil") == "Administrador";
    var podeCriar = Context.Session.GetString("UsuarioPerfil") != "Convidado";
    var currentUserId = int.TryParse(Context.Session.GetString("UsuarioId"), out var uid) ? uid : (int?)null;
}
<div class="content">
    @if (TempData["Erro"] != null)
    {
        <div style="background: rgba(239,68,68,.12); border: 1px solid #ef4444; color: #fca5a5; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 13px;">
            @TempData["Erro"]
        </div>
    }
    @if (TempData["Sucesso"] != null)
    {
        <div style="background: rgba(16,185,129,.12); border: 1px solid #10b981; color: #6ee7b7; padding: 12px 18px; border-radius: 10px; margin-bottom: 16px; font-size: 13px;">
            @TempData["Sucesso"]
        </div>
    }
    <div class="page-header">
        <div><h1 class="page-title">Agentes Digitais</h1><p class="page-sub">Gerencie os agentes do Agentic Context Engine</p></div>
        @if (podeCriar)
        {
            <a href="/Agentes/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Novo Agente</a>
        }
    </div>
    <div class="stats-grid">
        <div class="stat-card sc-blue"><div class="stat-top"><div class="stat-icon si-blue"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18" /></svg></div><span class="stat-badge sb-blue">Total</span></div><div class="stat-label">Agentes Digitais</div><div class="stat-val">@Model.Count</div><div class="stat-sub">No sistema</div></div>
        <div class="stat-card sc-green"><div class="stat-top"><div class="stat-icon si-green"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z" /></svg></div><span class="stat-badge sb-green">Ativos</span></div><div class="stat-label">Agentes Ativos</div><div class="stat-val">@Model.Count(a => a.Ativo)</div><div class="stat-sub"><span class="trend-up">Em operacao</span></div></div>
        <div class="stat-card sc-purple"><div class="stat-top"><div class="stat-icon si-purple"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" /></svg></div><span class="stat-badge sb-purple">Msgs</span></div><div class="stat-label">Mensagens</div><div class="stat-val">@ViewBag.TotalMensagens</div><div class="stat-sub">Total no banco</div></div>
        <div class="stat-card sc-amber"><div class="stat-top"><div class="stat-icon si-amber"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" /></svg></div><span class="stat-badge sb-amber">Mem</span></div><div class="stat-label">Memorias</div><div class="stat-val">@ViewBag.TotalMemorias</div><div class="stat-sub">Contextos salvos</div></div>
    </div>
    <div class="tcard">
        <div class="thead-row">
            <span class="thead-title">Todos os Agentes</span>
            <div class="toolbar">
                <div class="search-wrap"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg><input type="text" placeholder="Buscar..." oninput="filtrar(this.value,'tbody-ag')" /></div>
                <select class="filter-select" onchange="filtrarStatus(this.value,'tbody-ag')"><option value="">Todos</option><option value="ativo">Ativo</option><option value="inativo">Inativo</option></select>
                @if (podeCriar)
                {
                    <a href="/Agentes/Criar" class="tbtn"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>Novo</a>
                }
            </div>
        </div>
        <table>
            <thead><tr><th>#</th><th>Agente</th><th>Categoria</th><th>Descricao</th><th>Status</th><th>Criado em</th><th>Ações</th></tr></thead>
            <tbody id="tbody-ag">
                @{
                    int i = 0;
                }
                @foreach (var a in Model)
                {
                    i++;
                    <tr>
                        <td class="td-num">@i.ToString("D2")</td>
                        <td><div class="td-name"><div class="td-icon ti-purple"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18" /></svg></div>@a.Nome</div></td>
                        <td><span class="badge b-purple">@a.CategoriaNome</span></td>
                        <td class="td-muted">@a.Descricao</td>
                        <td>@if(a.Ativo){
                            <span class="badge b-green"><span class="dot dot-green"></span>Ativo</span>
                        }else
                        {

                            <span class="badge b-red"><span class="dot dot-red"></span>Inativo</span>
                        }
                    </td>
                    <td class="td-muted">@a.DataCriacao.ToString("dd/MM/yyyy")</td>
                    <td>
                        <template id="view-agente-@a.Id">
                            <div class="vrow"><span class="vlabel">Nome</span><span class="vvalue">@a.Nome</span></div>
                            <div class="vrow"><span class="vlabel">Categoria</span><span class="vvalue">@a.CategoriaNome</span></div>
                            <div class="vrow"><span class="vlabel">Descrição</span><span class="vvalue">@(a.Descricao ?? "-")</span></div>
                            <div class="vrow"><span class="vlabel">Instruções</span><span class="vvalue">@(a.Instrucoes ?? "-")</span></div>
                            <div class="vrow"><span class="vlabel">Status</span><span class="vvalue">@(a.Ativo ? "Ativo" : "Inativo")</span></div>
                            <div class="vrow"><span class="vlabel">Criado em</span><span class="vvalue">@a.DataCriacao.ToString("dd/MM/yyyy HH:mm")</span></div>
                        </template>
                        <div class="td-actions">
                            <a href="#" class="act act-view" title="Visualizar" onclick="abrirModalView('view-agente-@a.Id','@a.Nome'); return false;"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" /></svg></a>
                            @if (isAdmin || a.CriadoPorUsuarioId == currentUserId)
                            {
                                <a href="/Agentes/Editar/@a.Id" class="act act-edit" title="Editar"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg></a>
                                <a href="/Agentes/Excluir/@a.Id" class="act act-del" title="Excluir" onclick="return confirm('Excluir?')"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" /></svg></a>
                            }
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <div class="tfoot-row"><span class="tfoot-info">Mostrando @Model.Count agentes</span><div class="pag"><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" /></svg></a><a href="#" class="pg on">1</a><a href="#" class="pg"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" /></svg></a></div></div>
</div>
</div>