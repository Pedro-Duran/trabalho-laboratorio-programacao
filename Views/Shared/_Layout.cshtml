<main class="main">@RenderBody()</main>
<script>
function u(){var n=new Date();var el=document.getElementById("clock");if(el)el.textContent=n.toLocaleDateString("pt-BR",{weekday:"short",day:"2-digit",month:"short"})+" \u2022 "+n.toLocaleTimeString("pt-BR",{hour:"2-digit",minute:"2-digit"})}
u();setInterval(u,1000);
function filtrar(v,id){document.querySelectorAll("#"+id+" tr").forEach(function(r){r.style.display=r.innerText.toLowerCase().includes(v.toLowerCase())?"":"none"})}
function filtrarStatus(v,id){document.querySelectorAll("#"+id+" tr").forEach(function(r){if(!v){r.style.display="";return;}r.style.display=r.innerText.toLowerCase().includes(v)?"":"none"})}
</script>
