<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="utf-8" />
    <title>ACE Platform</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        :root{--bg:#07090f;--s1:#0c0f1a;--s2:#111827;--s3:#1a2235;--border:#1e2d42;--p:#6366f1;--p2:#4f46e5;--text:#f0f4ff;--muted:#6b7a99;--success:#10b981;--warning:#f59e0b;--danger:#ef4444;--purple:#8b5cf6;--cyan:#06b6d4}
        body{background:var(--bg);font-family:Inter,sans-serif;color:var(--text);display:flex;min-height:100vh;font-size:14px}
        .sidebar{width:250px;background:var(--s1);border-right:1px solid var(--border);display:flex;flex-direction:column;position:fixed;top:0;left:0;bottom:0;z-index:100}
        .sb-brand{padding:24px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:13px}
        .sb-logo{width:42px;height:42px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;box-shadow:0 0 20px rgba(99,102,241,0.4)}
        .sb-logo svg{width:22px;height:22px;fill:none;stroke:white;stroke-width:1.8}
        .t1{font-size:17px;font-weight:800;color:var(--text);letter-spacing:-0.5px}
        .t2{font-size:11px;color:var(--p);font-weight:500}
        .sb-user{padding:16px 20px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:11px;background:rgba(99,102,241,0.04)}
        .sb-avatar{width:40px;height:40px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;color:white;flex-shrink:0;position:relative;box-shadow:0 0 12px rgba(99,102,241,0.3)}
        .sb-avatar::after{content:'';position:absolute;bottom:1px;right:1px;width:10px;height:10px;background:#10b981;border-radius:50%;border:2px solid var(--s1)}
        .sb-uname{font-size:13px;font-weight:600;color:var(--text)}
        .sb-online{font-size:11px;color:#10b981;margin-top:2px}
        .sb-nav{padding:16px 10px;flex:1}
        .sb-sec{font-size:10px;font-weight:700;color:var(--muted);letter-spacing:1.5px;text-transform:uppercase;padding:10px 10px 6px}
        .nav-a{display:flex;align-items:center;gap:10px;padding:10px 12px;border-radius:10px;text-decoration:none;color:var(--muted);font-size:13px;font-weight:500;transition:all 0.15s;margin-bottom:3px;position:relative}
        .nav-a:hover{background:var(--s2);color:var(--text)}
        .nav-a.active{background:linear-gradient(135deg,rgba(99,102,241,0.15),rgba(139,92,246,0.1));color:var(--p);font-weight:600;border:1px solid rgba(99,102,241,0.2)}
        .nav-a svg{width:17px;height:17px;flex-shrink:0}
        .sb-promo{margin:12px;background:linear-gradient(135deg,rgba(99,102,241,0.1),rgba(139,92,246,0.08));border:1px solid rgba(99,102,241,0.2);border-radius:14px;padding:18px}
        .sb-promo h4{font-size:13px;font-weight:700;color:var(--p);margin-bottom:5px}
        .sb-promo p{font-size:11px;color:var(--muted);margin-bottom:12px;line-height:1.6}
        .sb-promo a{font-size:12px;color:white;font-weight:600;text-decoration:none;background:var(--p);padding:6px 14px;border-radius:7px;display:inline-block}
        .sb-footer{padding:14px 20px;border-top:1px solid var(--border);font-size:11px;color:var(--muted);line-height:1.7}
        .topbar{position:fixed;top:0;left:250px;right:0;height:60px;background:rgba(12,15,26,0.95);backdrop-filter:blur(10px);border-bottom:1px solid var(--border);display:flex;align-items:center;padding:0 28px;gap:14px;z-index:99}
        .tb-search{flex:1;max-width:380px;position:relative}
        .tb-search svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);width:16px;height:16px;fill:none;stroke:var(--muted);stroke-width:1.5}
        .tb-search input{width:100%;background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:9px 90px 9px 38px;color:var(--text);font-size:13px;font-family:Inter,sans-serif;outline:none;transition:all 0.2s}
        .tb-search input:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(99,102,241,0.1)}
        .tb-search input::placeholder{color:var(--muted)}
        .tb-kbd{position:absolute;right:10px;top:50%;transform:translateY(-50%);background:var(--s3);border:1px solid var(--border);border-radius:5px;padding:2px 8px;font-size:10px;color:var(--muted)}
        .tb-spacer{flex:1}
        .tb-time{font-size:12px;color:var(--muted);white-space:nowrap;padding:6px 12px;background:var(--s2);border:1px solid var(--border);border-radius:8px}
        .tb-actions{display:flex;align-items:center;gap:8px}
        .tb-icon{width:38px;height:38px;background:var(--s2);border:1px solid var(--border);border-radius:10px;display:flex;align-items:center;justify-content:center;cursor:pointer;position:relative;transition:all 0.15s}
        .tb-icon:hover{border-color:var(--p);background:rgba(99,102,241,0.08)}
        .tb-icon svg{width:17px;height:17px;fill:none;stroke:var(--muted);stroke-width:1.5}
        .tb-notif{position:absolute;top:-3px;right:-3px;width:18px;height:18px;background:linear-gradient(135deg,#ef4444,#dc2626);border-radius:50%;font-size:9px;font-weight:700;color:white;display:flex;align-items:center;justify-content:center;border:2px solid var(--s1)}
        .tb-user{display:flex;align-items:center;gap:9px;padding:7px 14px;background:var(--s2);border:1px solid var(--border);border-radius:10px;cursor:pointer;margin-left:2px;transition:all 0.15s}
        .tb-user:hover{border-color:var(--p)}
        .tb-uavatar{width:28px;height:28px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:700;color:white}
        .tb-uname{font-size:12px;font-weight:600;color:var(--text)}
        .tb-urole{font-size:10px;color:var(--muted)}
        .tb-user svg{width:13px;height:13px;fill:none;stroke:var(--muted);stroke-width:2}
        .tb-logout{width:38px;height:38px;background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.2);border-radius:10px;display:flex;align-items:center;justify-content:center;text-decoration:none;transition:all 0.15s}
        .tb-logout:hover{background:rgba(239,68,68,0.15);border-color:rgba(239,68,68,0.4)}
        .tb-logout svg{width:16px;height:16px;fill:none;stroke:#ef4444;stroke-width:2}
        .main{margin-left:250px;padding-top:60px;flex:1;min-height:100vh;overflow-x:auto}
        .content{padding:28px;min-width:820px}
        .page-header{margin-bottom:24px;display:flex;align-items:flex-start;justify-content:space-between;gap:16px}
        .page-title{font-size:22px;font-weight:800;color:var(--text);margin-bottom:4px;letter-spacing:-0.5px}
        .page-sub{font-size:13px;color:var(--muted)}
        .stats-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:16px;margin-bottom:24px}
        .stat-card{background:var(--s1);border:1px solid var(--border);border-radius:14px;padding:20px;position:relative;overflow:hidden;transition:all 0.2s;cursor:default}
        .stat-card:hover{border-color:var(--p);transform:translateY(-2px);box-shadow:0 8px 24px rgba(99,102,241,0.1)}
        .stat-card::before{content:'';position:absolute;top:0;right:0;width:80px;height:80px;border-radius:50%;opacity:0.06}
        .sc-blue::before{background:#6366f1}.sc-green::before{background:#10b981}.sc-amber::before{background:#f59e0b}.sc-purple::before{background:#8b5cf6}
        .stat-top{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:14px}
        .stat-icon{width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center}
        .stat-icon svg{width:21px;height:21px;fill:none;stroke-width:1.8}
        .si-blue{background:rgba(99,102,241,0.12)}.si-blue svg{stroke:#6366f1}
        .si-green{background:rgba(16,185,129,0.12)}.si-green svg{stroke:#10b981}
        .si-amber{background:rgba(245,158,11,0.12)}.si-amber svg{stroke:#f59e0b}
        .si-purple{background:rgba(139,92,246,0.12)}.si-purple svg{stroke:#8b5cf6}
        .stat-badge{font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px}
        .sb-blue{background:rgba(99,102,241,0.12);color:#6366f1}
        .sb-green{background:rgba(16,185,129,0.12);color:#10b981}
        .sb-amber{background:rgba(245,158,11,0.12);color:#f59e0b}
        .sb-purple{background:rgba(139,92,246,0.12);color:#8b5cf6}
        .stat-label{font-size:12px;color:var(--muted);font-weight:500;margin-bottom:6px}
        .stat-val{font-size:30px;font-weight:800;color:var(--text);letter-spacing:-1.5px;line-height:1}
        .stat-sub{font-size:11px;color:var(--muted);margin-top:8px}
        .trend-up{color:#10b981;font-weight:600}
        .tcard{background:var(--s1);border:1px solid var(--border);border-radius:14px;overflow:hidden}
        .thead-row{padding:18px 22px;border-bottom:1px solid var(--border);display:flex;align-items:center;gap:10px;flex-wrap:wrap;background:rgba(99,102,241,0.02)}
        .thead-title{font-size:15px;font-weight:700;color:var(--text);flex:1}
        .toolbar{display:flex;align-items:center;gap:8px;flex-wrap:wrap}
        .search-wrap{position:relative}
        .search-wrap svg{position:absolute;left:10px;top:50%;transform:translateY(-50%);width:14px;height:14px;fill:none;stroke:var(--muted);stroke-width:1.5;pointer-events:none}
        .search-wrap input{background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:8px 12px 8px 30px;color:var(--text);font-size:12px;font-family:Inter,sans-serif;outline:none;width:190px;transition:all 0.2s}
        .search-wrap input:focus{border-color:var(--p);width:220px}
        .search-wrap input::placeholder{color:var(--muted)}
        .filter-select{background:var(--s2);border:1px solid var(--border);border-radius:8px;padding:8px 12px;color:var(--muted);font-size:12px;font-family:Inter,sans-serif;outline:none;cursor:pointer;transition:all 0.2s}
        .filter-select:focus{border-color:var(--p)}
        .tbtn{display:inline-flex;align-items:center;gap:6px;padding:9px 18px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border:none;border-radius:10px;font-size:13px;font-weight:600;color:white;cursor:pointer;text-decoration:none;font-family:Inter,sans-serif;transition:all 0.2s;white-space:nowrap;box-shadow:0 4px 14px rgba(99,102,241,0.3)}
        .tbtn:hover{opacity:0.9;transform:translateY(-1px);box-shadow:0 6px 20px rgba(99,102,241,0.4)}
        .tbtn svg{width:14px;height:14px;fill:none;stroke:white;stroke-width:2.5}
        table{width:100%;border-collapse:collapse}
        thead tr{background:var(--s2)}
        th{padding:12px 20px;text-align:left;font-size:11px;font-weight:700;color:var(--muted);letter-spacing:0.8px;text-transform:uppercase;border-bottom:1px solid var(--border);white-space:nowrap}
        td{padding:15px 20px;font-size:13px;color:var(--text);border-bottom:1px solid var(--border);vertical-align:middle}
        tr:last-child td{border-bottom:none}
        tbody tr{transition:background 0.1s}
        tbody tr:hover{background:rgba(99,102,241,0.04)}
        .td-num{color:var(--muted);font-weight:700;font-size:12px;width:45px}
        .td-name{display:flex;align-items:center;gap:11px;font-weight:600}
        .td-icon{width:36px;height:36px;border-radius:10px;display:flex;align-items:center;justify-content:center;flex-shrink:0}
        .td-icon svg{width:17px;height:17px;fill:none;stroke-width:1.8}
        .ti-blue{background:rgba(99,102,241,0.12)}.ti-blue svg{stroke:#6366f1}
        .ti-green{background:rgba(16,185,129,0.12)}.ti-green svg{stroke:#10b981}
        .ti-amber{background:rgba(245,158,11,0.12)}.ti-amber svg{stroke:#f59e0b}
        .ti-purple{background:rgba(139,92,246,0.12)}.ti-purple svg{stroke:#8b5cf6}
        .ti-cyan{background:rgba(6,182,212,0.12)}.ti-cyan svg{stroke:#06b6d4}
        .td-url{color:#6366f1;font-size:12px;display:flex;align-items:center;gap:4px;text-decoration:none;font-weight:500}
        .td-url:hover{text-decoration:underline}
        .td-url svg{width:11px;height:11px;fill:none;stroke:currentColor;stroke-width:2}
        .badge{display:inline-flex;align-items:center;gap:5px;padding:4px 11px;border-radius:20px;font-size:11px;font-weight:600;white-space:nowrap}
        .b-green{background:rgba(16,185,129,0.1);color:#10b981;border:1px solid rgba(16,185,129,0.2)}
        .b-blue{background:rgba(99,102,241,0.1);color:#6366f1;border:1px solid rgba(99,102,241,0.2)}
        .b-purple{background:rgba(139,92,246,0.1);color:#8b5cf6;border:1px solid rgba(139,92,246,0.2)}
        .b-amber{background:rgba(245,158,11,0.1);color:#f59e0b;border:1px solid rgba(245,158,11,0.2)}
        .b-red{background:rgba(239,68,68,0.1);color:#ef4444;border:1px solid rgba(239,68,68,0.2)}
        .dot{width:6px;height:6px;border-radius:50%;display:inline-block}
        .dot-green{background:#10b981}.dot-red{background:#ef4444}
        .td-muted{font-size:12px;color:var(--muted);max-width:220px}
        .td-actions{display:flex;align-items:center;gap:6px}
        .act{width:32px;height:32px;border-radius:8px;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer;transition:all 0.15s;text-decoration:none}
        .act svg{width:14px;height:14px;fill:none;stroke:currentColor;stroke-width:2}
        .act-view{background:rgba(6,182,212,0.1);color:#06b6d4;border:1px solid rgba(6,182,212,0.15)}
        .act-view:hover{background:rgba(6,182,212,0.2);transform:scale(1.05)}
        .act-edit{background:rgba(99,102,241,0.1);color:#6366f1;border:1px solid rgba(99,102,241,0.15)}
        .act-edit:hover{background:rgba(99,102,241,0.2);transform:scale(1.05)}
        .act-del{background:rgba(239,68,68,0.06);color:#ef4444;border:1px solid rgba(239,68,68,0.15)}
        .act-del:hover{background:rgba(239,68,68,0.15);transform:scale(1.05)}
        .tfoot-row{padding:14px 22px;border-top:1px solid var(--border);display:flex;align-items:center;justify-content:space-between;background:rgba(99,102,241,0.02)}
        .tfoot-info{font-size:12px;color:var(--muted)}
        .pag{display:flex;gap:4px}
        .pg{width:30px;height:30px;border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:600;cursor:pointer;border:1px solid var(--border);background:var(--s2);color:var(--muted);text-decoration:none;transition:all 0.15s}
        .pg:hover,.pg.on{background:linear-gradient(135deg,#6366f1,#8b5cf6);border-color:transparent;color:white;box-shadow:0 4px 12px rgba(99,102,241,0.3)}
        .pg svg{width:12px;height:12px;fill:none;stroke:currentColor;stroke-width:2}
        .fcard{background:var(--s1);border:1px solid var(--border);border-radius:14px;padding:26px;max-width:600px}
        .fcard-title{font-size:16px;font-weight:700;color:var(--text);margin-bottom:22px;padding-bottom:18px;border-bottom:1px solid var(--border)}
        .fg{margin-bottom:20px}
        .flabel{display:block;font-size:13px;font-weight:500;color:var(--muted);margin-bottom:8px}
        .finput{width:100%;background:var(--s2);border:1px solid var(--border);border-radius:10px;padding:12px 16px;color:var(--text);font-size:14px;font-family:Inter,sans-serif;outline:none;transition:all 0.2s}
        .finput:focus{border-color:var(--p);box-shadow:0 0 0 3px rgba(99,102,241,0.1)}
        .finput::placeholder{color:var(--muted)}
        select.finput option{background:var(--s2);color:var(--text)}
        .factions{display:flex;gap:10px;margin-top:26px}
        .fsave{padding:11px 24px;background:linear-gradient(135deg,#6366f1,#8b5cf6);border:none;border-radius:10px;color:white;font-size:13px;font-weight:600;font-family:Inter,sans-serif;cursor:pointer;transition:all 0.2s;box-shadow:0 4px 14px rgba(99,102,241,0.3)}
        .fsave:hover{opacity:0.9;transform:translateY(-1px)}
        .fcancel{padding:11px 24px;background:var(--s2);border:1px solid var(--border);border-radius:10px;color:var(--muted);font-size:13px;font-weight:600;font-family:Inter,sans-serif;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;transition:all 0.15s}
        .fcancel:hover{color:var(--text);border-color:var(--p)}
    </style>
</head>
<body>
@{ var ctrl = ViewContext.RouteData.Values["controller"]?.ToString() ?? ""; }
<nav class="sidebar">
    <div class="sb-brand">
        <div class="sb-logo"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg></div>
        <div><div class="t1">ACE</div><div class="t2">Agentic Context Engine</div></div>
    </div>
    <div class="sb-user">
        <div class="sb-avatar">A</div>
        <div><div class="sb-uname">Administrador</div><div class="sb-online">&#x25cf; Online</div></div>
    </div>
<div class="sb-nav">
    <div class="sb-sec">Menu Principal</div>
    <a href="/Categorias/Index" class="nav-a @(ctrl=="Categorias"?"active":"")"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>Categorias</a>
    <a href="/Agentes/Index" class="nav-a @(ctrl=="Agentes"?"active":"")"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2"/></svg>Agentes</a>
    <a href="/Usuarios/Index" class="nav-a @(ctrl=="Usuarios"?"active":"")"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>Usuários</a>
    <a href="/Canais/Index" class="nav-a @(ctrl=="Canais"?"active":"")"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>Canais de Origem</a>
    
    <div class="sb-sec" style="margin-top:15px;">Simulador</div>
    <a href="/Simulacao/Index" class="nav-a @(ctrl=="Simulacao"?"active":"")" style="color: #8b5cf6;">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24" style="stroke: #8b5cf6;"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
        Simular Chat (Contexto)
    </a>
</div>
    <div class="sb-promo"><h4>&#x1F9E0; Inteligencia conectada.</h4><p>Memoria que evolui com cada interacao dos agentes digitais.</p><a href="#">Saiba mais &#x2192;</a></div>
    <div class="sb-footer">ACE Platform v2.0.0<br/>&#169; 2024 Agentic Context Engine</div>
</nav>
<header class="topbar">
    <div class="tb-search"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg><input type="text" placeholder="Buscar no sistema..." /><span class="tb-kbd">Ctrl+K</span></div>
    <div class="tb-spacer"></div>
    <div class="tb-time" id="clock"></div>
    <div class="tb-actions">
        <div class="tb-icon"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/></svg><span class="tb-notif">3</span></div>
