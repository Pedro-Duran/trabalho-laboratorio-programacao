@model AgenticContextEngine.Models.DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<style>
      .dashboard-card {
      border: none;
      border-radius: 18px;
      box-shadow: 0 8px 25px rgba(0,0,0,.08);
      transition: .3s;
    }

    .dashboard-card:hover {
       transform: translateY(-4px);
    }

    .chart-card {
       border: none;
       border-radius: 18px;
       overflow: hidden;
        box-shadow: 0 8px 25px rgba(0,0,0,.08);
    }

    .chart-card .card-header {
        background: linear-gradient(135deg,#4f46e5,#7c3aed);
        color: white;
        font-size: 15px;
      font-weight: 600;
      padding: 14px 18px;
      border: none;
    }

    .chart-card .card-body {
        background: white;
        padding: 20px;
    }

    .chart-container {
        position: relative;
        height: 280px;
    }

    .chart-container-small {
       position: relative;
       height: 240px;
    }

    .metric-number {
       font-size: 2.4rem;
       font-weight: 700;
    }

    .metric-label {
       font-size: .9rem;
      color: #6c757d;
    }

    .page-title {
      font-size: 2rem;
      font-weight: 700;
      color: #1e293b;
    }

    .page-subtitle {
        color: #64748b;
    }

    .chart-container {
        position: relative;
        height: 320px;
    }

    .chart-container-small {
        position: relative;
        height: 260px;
    }

    .metric-number {
        font-size: 2.3rem;
        font-weight: 700;
    }

    .metric-label {
        color: #6c757d;
        font-size: .9rem;
    }
</style>

<div class="container-fluid mt-4">

    <!-- TÍTULO -->

    <div class="row mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h2 class="page-title mb-1">
                    📊 Dashboard Executivo
                </h2>

                <div class="page-subtitle">
                    Monitoramento em tempo real da plataforma Agentic Context Engine
                </div>
            </div>
        </div>
    </div>
</div>
    <!-- CARDS -->

    <div class="row mb-4">

        <div class="col-md-3 mb-3">
    <div class="card dashboard-card">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-center">

                <div>
                    <div class="metric-number text-primary">
                        @Model.TotalUsuarios
                    </div>
                    <div class="text-muted">Usuários</div>
                </div>
            </div>
        </div>
    </div>
</div>

        <div class="col-md-3 mb-3">
            <div class="card dashboard-card">
                <div class="card-body text-center">
                    <div class="metric-number text-success">
                        @Model.TotalAgentes
                    </div>
                    <div class="text-muted">
                        Agentes
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card dashboard-card">
                <div class="card-body text-center">
                    <div class="metric-number text-warning">
                        @Model.TotalSessoes
                    </div>
                    <div class="text-muted">
                        Sessões
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-3">
            <div class="card dashboard-card">
                <div class="card-body text-center">
                    <div class="metric-number text-danger">
                        @Model.TotalMensagens
                    </div>
                    <div class="text-muted">
                        Mensagens
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- GRÁFICOS SUPERIORES -->

    <div class="row">

        <div class="col-lg-6 mb-4">
            <div class="card chart-card h-100">
                <div class="card-header">
                    Mensagens por Agente → 🤖 Performance dos Agentes
                </div>
                <div class="card-body">
                    <div class="chart-container-small">
                        <canvas id="graficoAgentes"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="card chart-card h-100">
                <div class="card-header">
                    Sessões por Canal → 🌐 Distribuição por Canal
                </div>
                <div class="card-body">
                    <div class="chart-container-small">
                        <canvas id="graficoCanais"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <!-- GRÁFICO INFERIOR -->

    <div class="row">

        <div class="col-12">
            <div class="card chart-card">
                <div class="card-header">
                    Evolução de Mensagens → 📈 Crescimento das Interações
                </div>
                <div class="card-body">
                    <div class="chart-container">
                        <canvas id="graficoMensagensDia"></canvas>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

const labelsAgentes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LabelsAgentes));
const valoresAgentes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresAgentes));

const labelsCanais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LabelsCanais));
const valoresCanais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresCanais));

const labelsDias = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LabelsDias));
const valoresDias = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresDias));

new Chart(document.getElementById('graficoAgentes'), {
    type: 'bar',
    data: {
        labels: labelsAgentes,
        datasets: [{
            label: 'Mensagens',
            data: valoresAgentes,
            backgroundColor: '#4F46E5'
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});

new Chart(document.getElementById('graficoCanais'), {
    type: 'pie',
    data: {
        labels: labelsCanais,
        datasets: [{
            data: valoresCanais,
            backgroundColor: [
                '#4F46E5',
                '#10B981',
                '#F59E0B',
                '#EF4444',
                '#8B5CF6'
            ]
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});

new Chart(document.getElementById('graficoMensagensDia'), {
    type: 'line',
    data: {
        labels: labelsDias,
        datasets: [{
            label: 'Mensagens',
            data: valoresDias,
            borderColor: '#4F46E5',
            backgroundColor: 'rgba(79,70,229,0.15)',
            fill: true,
            tension: 0.3
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
            legend: {
                position: 'bottom'
            }
        }
    }
});

</script>