@model AgenticContextEngine.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .dash-grid { display: grid; grid-template-columns: repeat(4, minmax(0,1fr)); gap: 16px; margin-bottom: 24px; }
    .dash-card { background: var(--s1); border: 1px solid var(--border); border-radius: 14px; padding: 20px; position: relative; overflow: hidden; transition: all .2s; }
    .dash-card:hover { border-color: var(--p); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(99,102,241,.1); }
    .dash-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
    .dash-icon svg { width: 21px; height: 21px; fill: none; stroke-width: 1.8; }
    .di-blue { background: rgba(99,102,241,.12); } .di-blue svg { stroke: #6366f1; }
    .di-green { background: rgba(16,185,129,.12); } .di-green svg { stroke: #10b981; }
    .di-amber { background: rgba(245,158,11,.12); } .di-amber svg { stroke: #f59e0b; }
    .di-red { background: rgba(239,68,68,.12); } .di-red svg { stroke: #ef4444; }
    .dash-num { font-size: 30px; font-weight: 800; color: var(--text); letter-spacing: -1.5px; line-height: 1; margin-bottom: 4px; }
    .dash-label { font-size: 12px; color: var(--muted); font-weight: 500; }
    .charts-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .chart-box { background: var(--s1); border: 1px solid var(--border); border-radius: 14px; overflow: hidden; }
    .chart-box-title { padding: 16px 20px; border-bottom: 1px solid var(--border); font-size: 14px; font-weight: 700; color: var(--text); display: flex; align-items: center; gap: 8px; background: rgba(99,102,241,.03); }
    .chart-box-body { padding: 20px; }
    .chart-area { position: relative; height: 260px; }
    .chart-area-tall { position: relative; height: 300px; }
    @@media (max-width: 900px) {
        .dash-grid { grid-template-columns: repeat(2, minmax(0,1fr)); }
        .charts-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="content">
    <div class="page-header">
        <div>
            <h1 class="page-title">Dashboard Executivo</h1>
            <p class="page-sub">Monitoramento em tempo real da plataforma Agentic Context Engine</p>
        </div>
    </div>

    <div class="dash-grid">
        <div class="dash-card">
            <div class="dash-icon di-blue"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div>
            <div class="dash-num">@Model.TotalUsuarios</div>
            <div class="dash-label">Usuários</div>
        </div>
        <div class="dash-card">
            <div class="dash-icon di-green"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2"/></svg></div>
            <div class="dash-num">@Model.TotalAgentes</div>
            <div class="dash-label">Agentes</div>
        </div>
        <div class="dash-card">
            <div class="dash-icon di-amber"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg></div>
            <div class="dash-num">@Model.TotalSessoes</div>
            <div class="dash-label">Sessões</div>
        </div>
        <div class="dash-card">
            <div class="dash-icon di-red"><svg viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg></div>
            <div class="dash-num">@Model.TotalMensagens</div>
            <div class="dash-label">Mensagens</div>
        </div>
    </div>

    <div class="charts-grid">
        <div class="chart-box">
            <div class="chart-box-title"><svg viewBox="0 0 24 24" style="width:16px;height:16px;display:inline-block;vertical-align:middle;margin-right:4px;" fill="none" stroke="#6366f1" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg> Performance dos Agentes</div>
            <div class="chart-box-body">
                <div class="chart-area">
                    <canvas id="graficoAgentes"></canvas>
                </div>
            </div>
        </div>
        <div class="chart-box">
            <div class="chart-box-title"><svg viewBox="0 0 24 24" style="width:16px;height:16px;display:inline-block;vertical-align:middle;margin-right:4px;" fill="none" stroke="#10b981" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg> Distribuição por Canal</div>
            <div class="chart-box-body">
                <div class="chart-area">
                    <canvas id="graficoCanais"></canvas>
                </div>
            </div>
        </div>
    </div>

    <div class="chart-box">
        <div class="chart-box-title"><svg viewBox="0 0 24 24" style="width:16px;height:16px;display:inline-block;vertical-align:middle;margin-right:4px;" fill="none" stroke="#f59e0b" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg> Crescimento das Interações</div>
        <div class="chart-box-body">
            <div class="chart-area-tall">
                <canvas id="graficoMensagensDia"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script>
const labelsAgentes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LabelsAgentes));
const valoresAgentes = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresAgentes));
const labelsCanais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LabelsCanais));
const valoresCanais = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresCanais));
const labelsDias = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.LabelsDias));
const valoresDias = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.ValoresDias));

Chart.defaults.color = '#94a3b8';
Chart.defaults.borderColor = '#1e2d42';
Chart.defaults.font.family = "'Inter', sans-serif";

new Chart(document.getElementById('graficoAgentes'), {
    type: 'bar',
    data: {
        labels: labelsAgentes,
        datasets: [{
            label: 'Mensagens',
            data: valoresAgentes,
            backgroundColor: '#6366f1',
            borderRadius: 8,
            maxBarThickness: 60
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: { beginAtZero: true, grid: { color: '#1e2d42' } },
            x: { grid: { display: false } }
        }
    }
});

new Chart(document.getElementById('graficoCanais'), {
    type: 'doughnut',
    data: {
        labels: labelsCanais,
        datasets: [{
            data: valoresCanais,
            backgroundColor: ['#6366f1', '#10b981', '#f59e0b', '#ef4444', '#8b5cf6', '#06b6d4'],
            borderWidth: 0
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { position: 'bottom', labels: { padding: 16 } } }
    }
});

new Chart(document.getElementById('graficoMensagensDia'), {
    type: 'line',
    data: {
        labels: labelsDias,
        datasets: [{
            label: 'Mensagens',
            data: valoresDias,
            borderColor: '#6366f1',
            backgroundColor: 'rgba(99,102,241,0.15)',
            fill: true,
            tension: 0.35,
            pointBackgroundColor: '#6366f1',
            pointBorderColor: '#0c0f1a',
            pointBorderWidth: 2,
            pointRadius: 4
        }]
    },
    options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
            y: { beginAtZero: true, grid: { color: '#1e2d42' } },
            x: { grid: { display: false } }
        }
    }
});
</script>